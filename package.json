{
  "name": "agent-journal",
  "version": "0.2.0",
  "description": "Persistent knowledge base & journal for coding agents.",
  "type": "module",
  "license": "MIT",
  "author": "Anees Iqbal <anees@usesimple.ai>",
  "homepage": "https://github.com/steelbrain/agent-journal#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/steelbrain/agent-journal.git"
  },
  "bugs": {
    "url": "https://github.com/steelbrain/agent-journal/issues"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "agent",
    "memory",
    "knowledge-base",
    "journal",
    "sqlite",
    "embeddings",
    "vector-search",
    "fts5"
  ],
  "bin": {
    "agent-journal": "dist/index.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "node scripts/build.mjs",
    "dev": "tsx src/index.ts",
    "format": "biome format --write .",
    "format:check": "biome format .",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "prepack": "npm run build"
  },
  "dependencies": {
    "@huggingface/transformers": "^4.2.0",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "better-sqlite3": "^12.11.1",
    "sqlite-vec": "^0.1.0",
    "ulid": "^3.0.2",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.1",
    "@types/better-sqlite3": "^7.6.0",
    "@types/node": "^20.0.0",
    "esbuild": "^0.28.1",
    "tsx": "^4.0.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9"
  }
}
